<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>AI_QUANT_DRAGON_TIGER</title>
    <style>
        :root {
            --jade-main: #4a7c64;
            --jade-light: #6b9a85;
            --jade-dark: #2c4a3b;
            --stone-grey: #6b737e;
            --inner-shadow: inset 8px 8px 16px rgba(0,0,0,0.4), inset -4px -4px 8px rgba(255,255,255,0.05);
            --gold: #f1c40f;
            --red-num: #ff4d4d;
            --blue-dragon: #3498db;
            --orange-tiger: #e67e22;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: sans-serif; -webkit-tap-highlight-color: transparent; }
        body { background: #1a1a1a; height: 100vh; display: flex; justify-content: center; align-items: center; overflow: hidden; }

        .phone-container {
            width: 100vw; height: 100vh; max-width: 480px;
            background: var(--jade-main);
            border: 12px solid var(--jade-main); 
            border-image: linear-gradient(135deg, var(--jade-light), var(--jade-dark)) 12;
            box-shadow: 5px 5px 15px rgba(0,0,0,0.5);
            display: flex; flex-direction: column;
        }

        .divider { height: 8px; background: var(--jade-dark); border-top: 2px solid var(--jade-light); border-bottom: 2px solid #000; width: 100%; }

        /* 顶部余额区 */
        .header-section { height: 12%; display: grid; grid-template-columns: 1fr 1fr; gap: 10px; padding: 12px; }
        .inset-box { background: var(--stone-grey); border: 2px solid var(--jade-dark); box-shadow: var(--inner-shadow); border-radius: 8px; display: flex; flex-direction: column; justify-content: center; align-items: center; }

        /* 转盘区 */
        .wheel-section { height: 40%; display: flex; justify-content: center; align-items: center; position: relative; background: var(--stone-grey); box-shadow: var(--inner-shadow); border: 4px solid var(--jade-dark); border-radius: 12px; margin: 0 8px; }
        .pointer { position: absolute; top: 6%; z-index: 10; width: 0; height: 0; border-left: 12px solid transparent; border-right: 12px solid transparent; border-top: 22px solid var(--red-num); }
        #wheel { width: 250px; height: 250px; border-radius: 50%; border: 10px solid var(--jade-main); background: #2a2a2a; position: relative; transition: transform 4s cubic-bezier(0.1, 0, 0.2, 1.1); }
        .slot { position: absolute; width: 100%; height: 100%; text-align: center; padding-top: 20px; font-size: 26px; }
        .hub { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 60px; height: 60px; background: var(--jade-dark); border-radius: 50%; border: 2px solid var(--jade-light); display: flex; align-items: center; justify-content: center; color: var(--gold); font-size: 12px; font-weight: bold; }

        /* 底部操作与龙虎斗区域 */
        .footer-section {
            flex: 1; display: flex; flex-direction: column; justify-content: flex-end; 
            padding: 10px 12px 12px 12px; background: var(--stone-grey); box-shadow: var(--inner-shadow);
            border: 4px solid var(--jade-dark); border-radius: 12px; margin: 8px 8px 10px 8px;
        }

        /* 龙虎斗内陷空格区 */
        .bet-grid {
            display: grid; grid-template-columns: 1fr 0.8fr 1fr; gap: 8px; margin-bottom: 15px; height: 100px;
        }
        .bet-side {
            background: rgba(0,0,0,0.2); border: 2px solid var(--jade-dark); border-radius: 10px;
            box-shadow: var(--inner-shadow); display: flex; flex-direction: column; align-items: center; justify-content: center;
            font-weight: bold; font-size: 24px; transition: 0.2s;
        }
        .bet-side:active { transform: scale(0.95); background: rgba(0,0,0,0.4); }
        .dragon { color: var(--blue-dragon); }
        .tiger { color: var(--orange-tiger); }
        .bet-label { font-size: 10px; color: #aaa; margin-top: 4px; }

        .bet-middle {
            display: grid; grid-template-rows: repeat(3, 1fr); gap: 4px;
        }
        .bet-mid-box {
            background: rgba(0,0,0,0.2); border: 1.5px solid var(--jade-dark); border-radius: 5px;
            box-shadow: var(--inner-shadow); display: flex; align-items: center; justify-content: center;
            font-size: 12px; color: var(--gold); font-weight: bold;
        }

        /* 按钮组 */
        .stake-info { text-align: center; color: #fff; font-size: 13px; font-weight: bold; margin-bottom: 8px; }
        .main-action { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
        .side-btn { width: 45px; height: 45px; background: var(--jade-main); border: 2px solid var(--jade-dark); border-radius: 8px; color: white; font-size: 20px; }
        .execute-btn { flex: 1; height: 55px; background: linear-gradient(180deg, #e53935, #b71c1c); border: none; border-radius: 28px; color: white; font-size: 18px; font-weight: bold; box-shadow: 0 5px 0 #7f0000; }
        .sub-action { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
        .func-btn { background: rgba(0,0,0,0.3); border: 2px solid var(--jade-dark); height: 38px; border-radius: 8px; color: #eee; font-size: 11px; display: flex; align-items: center; justify-content: center; }
        .func-btn.active { border-color: var(--gold); background: var(--jade-dark); }
        
        .blur { filter: blur(4px); }
    </style>
</head>
<body>

<div class="phone-container">
    <div class="header-section">
        <div class="inset-box"><span class="label">BALANCE</span><span class="val" id="ui-bal" style="color:var(--red-num)">146.80</span></div>
        <div class="inset-box"><span class="label">NETWORK POOL</span><span class="val" id="ui-pool" style="color:var(--gold)">84291.50</span></div>
    </div>

    <div class="divider"></div>

    <div class="wheel-section">
        <div class="pointer"></div>
        <div id="wheel"></div>
        <div class="hub" id="ui-hub">READY</div>
    </div>

    <div class="divider"></div>

    <div class="footer-section">
        <div class="bet-grid">
            <div class="bet-side dragon" onclick="selectBet('DRAGON')">
                龙
                <span class="bet-label">1:2</span>
            </div>
            <div class="bet-middle">
                <div class="bet-mid-box" onclick="selectBet('TIE')">和</div>
                <div class="bet-mid-box" onclick="selectBet('SMALL')">小</div>
                <div class="bet-mid-box" onclick="selectBet('BIG')">大</div>
            </div>
            <div class="bet-side tiger" onclick="selectBet('TIGER')">
                虎
                <span class="bet-label">1:2</span>
            </div>
        </div>

        <div class="stake-info">STAKE: <span id="ui-bet" style="color:var(--gold)">5.5</span> USDT</div>

        <div class="main-action">
            <button class="side-btn" onclick="App.adjBet(-1)">−</button>
            <button class="execute-btn" onclick="App.roll()" id="btn-go">EXECUTE</button>
            <button class="side-btn" onclick="App.adjBet(1)">+</button>
        </div>

        <div class="sub-action">
            <div class="func-btn" id="opt-auto" onclick="App.toggleAuto()">🤖 AUTO: OFF</div>
            <div class="func-btn" id="opt-speed" onclick="App.toggleSpeed()">⚡ SPEED: 1X</div>
        </div>
    </div>
</div>

<script>
function selectBet(type) {
    console.log("Selected:", type);
    // 这里可以添加选中状态的样式逻辑
}

const App = {
    bets: [5.5, 10.0, 20.0, 50.0, 100.0],
    icons: ['💎','💊','⚡','🔥','💰','🦁','🏆','🎲'],
    state: { bal: 146.80, betIdx: 0, deg: 0, isRolling: false, auto: false, speed: 1 },
    init() {
        const wheel = document.getElementById('wheel');
        this.icons.forEach((s, i) => {
            const el = document.createElement('div');
            el.className = 'slot'; el.style.transform = `rotate(${i * 45}deg)`; el.innerText = s;
            wheel.appendChild(el);
        });
        this.updateUI();
    },
    adjBet(dir) {
        if(this.state.isRolling) return;
        this.state.betIdx = Math.max(0, Math.min(this.bets.length-1, this.state.betIdx + dir));
        this.updateUI();
    },
    toggleSpeed() {
        this.state.speed = (this.state.speed % 3) + 1;
        document.getElementById('wheel').style.transitionDuration = {1:'4s', 2:'2s', 3:'0.8s'}[this.state.speed];
        this.updateUI();
    },
    toggleAuto() {
        this.state.auto = !this.state.auto;
        if(this.state.auto && !this.state.isRolling) this.roll();
        this.updateUI();
    },
    async roll() {
        const cost = this.bets[this.state.betIdx];
        if(this.state.isRolling || this.state.bal < cost) { this.state.auto = false; this.updateUI(); return; }
        this.state.isRolling = true; this.state.bal -= cost;
        document.getElementById('ui-hub').innerText = "SPINNING";
        document.getElementById('wheel').classList.add('blur');
        this.updateUI();
        const winIdx = Math.floor(Math.random() * 8);
        const rounds = this.state.speed === 1 ? 8 : (this.state.speed === 2 ? 5 : 3);
        const targetDeg = (360 - (this.state.deg % 360)) + (rounds * 360) - (winIdx * 45);
        this.state.deg += targetDeg;
        document.getElementById('wheel').style.transform = `rotate(${this.state.deg}deg)`;
        setTimeout(() => {
            document.getElementById('wheel').classList.remove('blur');
            this.state.isRolling = false;
            if(Math.random() > 0.7) { this.state.bal += cost * 3; document.getElementById('ui-hub').innerText = "WIN!"; }
            else { document.getElementById('ui-hub').innerText = "LOSE"; }
            this.updateUI();
            if(this.state.auto) setTimeout(() => this.roll(), 800);
        }, {1:4000, 2:2000, 3:800}[this.state.speed]);
    },
    updateUI() {
        document.getElementById('ui-bal').innerText = this.state.bal.toFixed(2);
        document.getElementById('ui-bet').innerText = this.bets[this.state.betIdx].toFixed(1);
        document.getElementById('opt-auto').className = this.state.auto ? "func-btn active" : "func-btn";
        document.getElementById('opt-auto').innerText = "🤖 AUTO: " + (this.state.auto ? "ON" : "OFF");
        document.getElementById('opt-speed').innerText = "⚡ SPEED: " + this.state.speed + "X";
        document.getElementById('btn-go').disabled = this.state.isRolling;
    }
};
App.init();
</script>
</body>
</html>